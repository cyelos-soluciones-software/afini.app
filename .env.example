# Documentación del proyecto: README.md, AGENTS.md (Cursor), docs/ARCHITECTURE.md
#
# URL pública (wa.me y enlaces). En Vercel suele inferirse; en local: http://localhost:3000
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Copia a .env y ajusta valores locales
# Puerto 5433 en host si 5432 ya está ocupado (ver docker-compose.yml)
DATABASE_URL="postgresql://eco:eco@localhost:5433/eco"

# NextAuth (genera con: openssl rand -base64 32)
AUTH_SECRET=""

# Solo desarrollo: contraseña de super@eco.local, admin@eco.local y lider@eco.local
DEV_SEED_PASSWORD="ChangeMe123!"

# Gemini (solo servidor). Misma clave que en curl: header X-goog-api-key
# GOOGLE_GENERATIVE_AI_API_KEY=""
# GEMINI_API_KEY=""
# Opcional: mismo nombre que en la URL REST (por defecto gemini-flash-latest)
# GEMINI_MODEL="gemini-flash-latest"

# Rate limit distribuido (funnel /api/funnel/stream). Sin esto se usa límite en memoria.
# Crea un Redis en https://console.upstash.com y copia REST URL + token.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

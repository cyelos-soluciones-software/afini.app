# Documentación del proyecto: README.md, AGENTS.md (Cursor), docs/ARCHITECTURE.md
#
# URL pública (wa.me y enlaces). En producción: https://afini.app
# NEXT_PUBLIC_APP_URL="https://afini.app"

# Copia a .env y ajusta valores locales
# Puerto 5433 si 5432 está ocupado. Usuario/base `eco` = solo local con docker-compose; producción = Neon, etc.
DATABASE_URL="postgresql://eco:eco@localhost:5433/eco"

# NextAuth (genera con: openssl rand -base64 32)
AUTH_SECRET="JD3+W5m8ndQergEhKc8htz1OQID0DduPM1sxY71e29o="
# Opcional en local: URL canónica de la app (misma que uses en el navegador; evita mezclar localhost y 127.0.0.1)
# AUTH_URL="http://localhost:3000"

# Solo desarrollo: contraseña de super@afini.local, admin@afini.local y lider@afini.local
DEV_SEED_PASSWORD="ChangeMe123!"

# Gemini (solo servidor). Misma clave que en curl: header X-goog-api-key
# GOOGLE_GENERATIVE_AI_API_KEY=""
# GEMINI_API_KEY=""
# Opcional: mismo nombre que en la URL REST (por defecto gemini-flash-latest)
# GEMINI_MODEL="gemini-flash-latest"

# Rate limit distribuido (funnel /api/funnel/stream). Sin esto se usa límite en memoria.
# Crea un Redis en https://console.upstash.com y copia REST URL + token.
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Cloudflare Turnstile (funnel público, antes de «Ver conclusión»). Site key pública; secret solo servidor.
# Dashboard: https://dash.cloudflare.com/ → Turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""

# Google OAuth (administradores de campaña). Credencial tipo "Aplicación web" en Google Cloud Console.
# Orígenes autorizados: http://localhost:3000 (dev) y https://afini.app (prod).
# URIs de redirección: http://localhost:3000/api/auth/callback/google y https://afini.app/api/auth/callback/google
# NO uses el JSON de cuenta de servicio para esto.
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
